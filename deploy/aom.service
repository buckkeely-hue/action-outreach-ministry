[Unit]
Description=Action Outreach Ministry Web Server
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/action-outreach-ministry
ExecStart=/usr/bin/python3 server.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
